ENVIRONMENT=development
# demo no transcribe ni evalúa. Use real únicamente con credenciales y modelos verificados.
AI_MODE=demo
DATABASE_URL=sqlite+aiosqlite:///./apps/api/data/b2_speaking.db
AUTO_CREATE_DB=true
ENABLE_INLINE_WORKER=true
WORKER_HEARTBEAT_SECONDS=10
STALE_JOB_SECONDS=150

# Sustituya ambos valores antes de cualquier despliegue público.
SESSION_TOKEN_PEPPER=replace-with-at-least-32-random-characters
UPLOAD_SIGNING_SECRET=replace-with-a-different-32-character-secret
TEACHER_VALIDATION_TOKEN=

PUBLIC_API_URL=http://localhost:8000
CORS_ALLOWED_ORIGINS=http://localhost:3000
TRUSTED_HOSTS=localhost,127.0.0.1,testserver
MAX_AUDIO_BYTES=8388608
SESSION_RETENTION_MINUTES=60

# local para desarrollo; supabase para despliegue.
STORAGE_MODE=local
LOCAL_STORAGE_PATH=./apps/api/data/storage
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=part2-recordings

# Proveedor recomendado para este proyecto. La clave vive solo en FastAPI/Railway,
# nunca en NEXT_PUBLIC_* ni en el navegador.
AI_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TRANSCRIPTION_MODEL=openai/whisper-large-v3
OPENROUTER_EVALUATION_MODEL=nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_EVALUATION_FALLBACK_MODELS=tencent/hy3:free,openrouter/free
OPENROUTER_PRONUNCIATION_MODEL=google/gemini-2.5-flash
OPENROUTER_PRONUNCIATION_FALLBACK_MODELS=openrouter/free
OPENROUTER_PARTNER_MODEL=tencent/hy3:free
OPENROUTER_PARTNER_FALLBACK_MODELS=nvidia/nemotron-3-super-120b-a12b:free,openrouter/free
OPENROUTER_MODEL_ATTEMPT_TIMEOUT_SECONDS=45
OPENROUTER_COMPLETION_BUDGET_SECONDS=90
OPENROUTER_HTTP_REFERER=http://localhost:3000
OPENROUTER_APP_NAME=B2 Speaking Academy

# Alternativa opcional si se selecciona AI_PROVIDER=openai.
OPENAI_API_KEY=
# Necesaria solo para Part 3 con dos candidatos. OpenRouter no devuelve etiquetas de hablante.
OPENAI_DIARIZATION_API_KEY=
OPENAI_DIARIZATION_MODEL=gpt-4o-transcribe-diarize
# Alternativa local gratuita para Part 3. Requiere el entorno aislado de WhisperX,
# una GPU compatible y acceso aceptado a pyannote/speaker-diarization-community-1.
# openai, whisperx (solo local) o modal (GPU serverless).
DIARIZATION_PROVIDER=openai
WHISPERX_PYTHON_PATH=.whisperx-venv/Scripts/python.exe
WHISPERX_BRIDGE_PATH=apps/api/scripts/whisperx_diarize.py
WHISPERX_MODEL=large-v3-turbo
WHISPERX_DEVICE=cuda
WHISPERX_COMPUTE_TYPE=float16
WHISPERX_BATCH_SIZE=8
WHISPERX_TIMEOUT_SECONDS=300
MODAL_APP_NAME=b2-speaking-whisperx
MODAL_CLASS_NAME=WhisperXWorker
MODAL_ENVIRONMENT_NAME=main
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
MODAL_TIMEOUT_SECONDS=600
# whisper-1 se mantiene por los timestamps de segmento requeridos por las citas del informe.
OPENAI_TRANSCRIPTION_MODEL=whisper-1
OPENAI_EVALUATION_MODEL=gpt-5.6-sol
OPENAI_PRONUNCIATION_MODEL=gpt-audio-1.5
OPENAI_TIMEOUT_SECONDS=90

# Perfiles propuestos, todavía no activos ni verificados por el mero hecho de configurarlos.
# El examinador final debe seleccionarse mediante el benchmark ciego de docs/v3.
EXAMINER_VOICE_PROVIDER=azure_speech
EXAMINER_VOICE_LOCALE=en-GB
EXAMINER_VOICE_NAME=en-GB-SoniaNeural
EXAMINER_VOICE_PROFILE_VERIFIED=false

# Realtime: marin/cedar son candidatos de benchmark, no garantía contractual de acento en-GB.
AI_PARTNER_VOICE_PROVIDER=openai_realtime
AI_PARTNER_VOICE_LOCALE=en-GB
AI_PARTNER_VOICE_NAME=marin
AI_PARTNER_VOICE_PROFILE_VERIFIED=false
