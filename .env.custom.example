# CUSTOM MODE — server-side values only. Never use NEXT_PUBLIC_* for secrets.
AI_MODE=real
AI_PROVIDER=openrouter
OPENROUTER_API_KEY=
GEMINI_API_KEY=

# Change model identifiers to models supported by your account/provider.
OPENROUTER_TRANSCRIPTION_MODEL=openai/whisper-large-v3
OPENROUTER_EVALUATION_MODEL=nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_EVALUATION_FALLBACK_MODELS=tencent/hy3:free,openrouter/free
OPENROUTER_PRONUNCIATION_MODEL=google/gemini-2.5-flash
OPENROUTER_PRONUNCIATION_FALLBACK_MODELS=openrouter/free
OPENROUTER_PARTNER_MODEL=tencent/hy3:free
OPENROUTER_PARTNER_FALLBACK_MODELS=nvidia/nemotron-3-super-120b-a12b:free,openrouter/free

# Optional: Part 3 with two candidates.
# openai requires OPENAI_DIARIZATION_API_KEY.
# whisperx runs locally but requires its separate Python/GPU environment.
DIARIZATION_PROVIDER=openai
OPENAI_DIARIZATION_API_KEY=
OPENAI_DIARIZATION_MODEL=gpt-4o-transcribe-diarize

# Optional cloud storage. Local storage is the default and needs no credentials.
STORAGE_MODE=local
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
